# Copia este archivo como .env y llena tus credenciales reales
# NUNCA subas el archivo .env a GitHub

# CoinMarketCap
CMC_API_KEY=tu_api_key_aqui

# Trust Wallet Agent Kit
TWAK_ACCESS_ID=tu_access_id_aqui
TWAK_HMAC_SECRET=tu_hmac_secret_aqui
TWAK_WALLET_PASSWORD=tu_password_de_wallet_aqui
TWAK_BSC_SPONSORED_RPC_URL=https://bsc-dataseed.binance.org

# Configuracion del agente
CAPITAL_TOTAL=100
CAPITAL_POR_POSICION=50
VOLUMEN_THRESHOLD=5
VOLUMEN_TIMEFRAME_MIN=5
MAX_POSICIONES=2
RED=bsc

# Telegram (para el funder de stablecoins)
TELEGRAM_API_ID=tu_telegram_api_id_aqui
TELEGRAM_API_HASH=tu_telegram_api_hash_aqui
TELEGRAM_PHONE=+tu_numero_de_telefono
STABLECOINS_BOT_USERNAME=@tu_bot_de_stablecoins

# Anthropic / Claude
ANTHROPIC_API_KEY=tu_anthropic_api_key_aqui
# Poner en true SOLO el dia de la competicion (22 junio)
CLAUDE_ENABLED=false

# Dashboard (token de acceso al panel web)
# Generar uno con: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_TOKEN=tu_token_secreto_aqui
